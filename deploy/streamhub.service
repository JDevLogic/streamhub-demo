[Unit]
Description=StreamHub Backend
After=network.target

[Service]
User=streamhub
WorkingDirectory=/opt/streamhub/backend
EnvironmentFile=/opt/streamhub/backend/.env
ExecStart=/opt/streamhub/backend/venv/bin/uvicorn app:app --host 127.0.0.1 --port 5050 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
