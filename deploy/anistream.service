[Unit]
Description=AniStream Backend
After=network.target

[Service]
User=root
WorkingDirectory=/root/anistream/backend
EnvironmentFile=/root/anistream/backend/.env
ExecStart=/root/anistream/backend/venv/bin/uvicorn app:app --host 127.0.0.1 --port 5050 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
