# Normalizar todos los archivos de texto a LF al hacer commit
* text=auto eol=lf

# Código
*.py    text eol=lf
*.dart  text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.xml   text eol=lf
*.kt    text eol=lf
*.kts   text eol=lf

# Scripts Windows — necesitan CRLF para ejecutarse correctamente
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binarios — sin conversión
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.jar   binary
*.zip   binary
*.db    binary
